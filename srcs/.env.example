# Copy this file to .env and fill in real values:
#   cp .env.example .env
# Passwords are NOT set here -- see secrets/ and DEV_DOC.md.

# Domain
DOMAIN_NAME=login.42.fr

# MariaDB
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user

# WordPress admin (created on first setup)
WP_ADMIN_USER=changeme
WP_ADMIN_EMAIL=changeme@example.com

# WordPress second user (non-admin)
WP_USER=changeme
WP_USER_EMAIL=changeme@example.com
